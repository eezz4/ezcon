{
  "name": "ezcon",
  "version": "1.1.0",
  "description": "React Easy Context",
  "author": "eezz4",
  "license": "MIT",
  "repository": "eezz4/ezcon",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "jsdom": "^29.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "ezcon",
    "react easy context",
    "scope Provider",
    "combination of Providers",
    "createContext",
    "useContext",
    "Provider",
    "useState",
    "ezState",
    "useRef",
    "ezRef",
    "ezCombineProvider"
  ]
}
